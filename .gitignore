# LaTeX build artifacts (redirected to build/ by .latexmkrc, but ignore
# stragglers too in case someone compiles without latexmk).
# The combined PDF is tracked so it's downloadable straight from GitHub.
build/*
!build/main.pdf
*.aux
*.log
*.out
*.toc
*.synctex.gz
*.fls
*.fdb_latexmk
*.bbl
*.bcf
*.blg
*.run.xml
*.nav
*.snm
*.vrb

# OS / editor cruft
.DS_Store
